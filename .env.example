# TRANSIT-AI Environment Configuration
# Copy to .env and fill values

# MAST API (optional — public access works without key)
MAST_API_TOKEN=your_mast_token_here

# Pipeline behavior
TESS_SECTOR=1
MAX_LIGHTCURVES=500
USE_SYNTHETIC_FALLBACK=true
N_PARALLEL_JOBS=4

# Detection thresholds
SNR_THRESHOLD=7.0
SDE_THRESHOLD=7.0
MIN_TRANSITS=2

# Dashboard
STREAMLIT_PORT=8501
STREAMLIT_THEME=dark

# Paths (optional overrides)
DATA_DIR=./data
MODELS_DIR=./models
REPORTS_DIR=./reports

# Model training
N_PER_CLASS=800
USE_SMOTE=true
MCMC_STEPS=2000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/transit_ai.log
